---
interface Props {
  title: string;
  price: string;
  imageColor: string;
  scent: string;
  id?: string;
}
const { title, price, imageColor, scent, id = title.toLowerCase().replace(/\s+/g, '-') } = Astro.props;
---
<article class="product-card reveal" data-scent={scent}>
  <a href={`/shop/${id}`} class="card-img-link" tabindex="-1" aria-hidden="true">
    <div class="card-img" style={`background-color:${imageColor}`}>
      <div class="soap-bar"></div>
    </div>
  </a>
  <button class="wishlist-btn" data-id={id} data-title={title} aria-label={`Save ${title} to wishlist`}>
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
    </svg>
  </button>
  <div class="card-body">
    <div class="card-info">
      <a href={`/shop/${id}`}><h3 class="card-title">{title}</h3></a>
      <p class="card-scent">{scent}</p>
    </div>
    <div class="card-footer">
      <span class="card-price">£{price}</span>
      <button class="add-btn"
        data-id={id} data-title={title}
        data-price={price} data-scent={scent}
        data-color={imageColor.replace('#','')}
        aria-label={`Add ${title} to basket`}>
        + Add
      </button>
    </div>
  </div>
</article>

<style>
  .product-card {
    position:relative;
    background-color:var(--clr-surface);
    border:1px solid var(--clr-border);
    border-radius:var(--r-lg); overflow:hidden;
    display:flex; flex-direction:column;
    transition:transform var(--transition), box-shadow var(--transition);
  }
  .product-card:hover { transform:translateY(-4px); box-shadow:var(--shadow-lg); }
  .card-img-link { display:block; }
  .card-img { aspect-ratio:4/3; display:flex; align-items:center; justify-content:center; overflow:hidden; }
  .soap-bar {
    width:55%; aspect-ratio:7/5; background:rgba(255,255,255,0.28);
    border-radius:14px; box-shadow:inset -4px -4px 12px rgba(0,0,0,0.08),6px 10px 24px rgba(0,0,0,0.15);
    transition:transform 0.4s cubic-bezier(0.34,1.56,0.64,1);
  }
  .product-card:hover .soap-bar { transform:rotate(-4deg) scale(1.05); }

  /* Wishlist */
  .wishlist-btn {
    position:absolute; top:var(--sp-3); right:var(--sp-3);
    width:34px; height:34px; border-radius:var(--r-full);
    background-color:var(--clr-surface); border:1px solid var(--clr-border);
    display:flex; align-items:center; justify-content:center;
    color:var(--clr-text-faint);
    transition:color var(--transition), background-color var(--transition), transform var(--transition);
    z-index:2;
  }
  .wishlist-btn:hover { color:var(--clr-primary); background-color:var(--clr-surface-2); transform:scale(1.1); }
  .wishlist-btn.saved { color:#e05555; fill:#e05555; }
  .wishlist-btn.saved svg { fill:#e05555; stroke:#e05555; }

  .card-body { padding:var(--sp-5); display:flex; flex-direction:column; gap:var(--sp-4); flex:1; }
  .card-info { flex:1; }
  .card-title { font-family:var(--font-display); font-size:var(--text-lg); font-weight:400; color:var(--clr-text); transition:color var(--transition); }
  a:hover .card-title { color:var(--clr-primary); }
  .card-scent { font-size:var(--text-xs); color:var(--clr-text-muted); text-transform:uppercase; letter-spacing:0.08em; margin-top:4px; }
  .card-footer { display:flex; align-items:center; justify-content:space-between; padding-top:var(--sp-3); border-top:1px solid var(--clr-border); }
  .card-price { font-family:var(--font-display); font-size:var(--text-xl); font-weight:400; color:var(--clr-text); }
  .add-btn {
    display:flex; align-items:center; gap:var(--sp-1);
    padding:var(--sp-2) var(--sp-4);
    background-color:var(--clr-text); color:var(--clr-bg);
    border-radius:var(--r-full); border:none; cursor:pointer;
    font-size:var(--text-xs); font-weight:600; text-transform:uppercase; letter-spacing:0.06em;
    transition:background-color var(--transition), transform var(--transition);
  }
  .add-btn:hover { background-color:var(--clr-primary); transform:scale(1.04); }
  .add-btn:active { transform:scale(0.96); }
  .add-btn.added { background-color:var(--clr-accent); }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    // Wishlist
    let wishlist: string[] = [];
    try { wishlist = JSON.parse(localStorage.getItem('sb_wishlist') || '[]'); } catch { /* ignore storage access errors */ }

    document.querySelectorAll<HTMLButtonElement>('.wishlist-btn').forEach(btn => {
      const id = btn.dataset.id!;
      if (wishlist.includes(id)) btn.classList.add('saved');
      btn.addEventListener('click', () => {
        try { wishlist = JSON.parse(localStorage.getItem('sb_wishlist') || '[]'); } catch { /* ignore storage access errors */ }
        if (wishlist.includes(id)) {
          wishlist = wishlist.filter(w => w !== id);
          btn.classList.remove('saved');
          btn.setAttribute('aria-label', `Save ${btn.dataset.title} to wishlist`);
        } else {
          wishlist.push(id);
          btn.classList.add('saved');
          btn.setAttribute('aria-label', `Remove ${btn.dataset.title} from wishlist`);
        }
        try { localStorage.setItem('sb_wishlist', JSON.stringify(wishlist)); } catch { /* ignore storage access errors */ }
      });
    });

    // Add to cart
    document.querySelectorAll<HTMLButtonElement>('.add-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const { id, title, price, scent, color } = btn.dataset;
        if (!id || !title || !price || !scent || !color) {
          console.error('Missing product dataset for add-to-cart button');
          return;
        }

        window.cartState?.addItem({
          id,
          title,
          price,
          scent,
          color,
        });
        btn.classList.add('added');
        btn.textContent = '✓ Added';
        setTimeout(() => { btn.classList.remove('added'); btn.textContent = '+ Add'; }, 1800);
      });
    });
  });
</script>
