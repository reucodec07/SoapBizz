---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import { getAllProducts } from '../lib/content';

const products = await getAllProducts();

const featuredIds = ['citrus-burst', 'lavender-dream', 'charcoal-detox', 'ocean-breeze'];
const featuredProducts = featuredIds
  .map((id) => products.find((product) => product.id === id))
  .filter((product): product is NonNullable<typeof product> => Boolean(product));
---
<Layout title="Home">
  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <div class="blob blob-a"></div>
      <div class="blob blob-b"></div>
    </div>
    <div class="container hero-inner">
      <div class="hero-text">
        <span class="ui-eyebrow reveal">Small Batch * Cold Pressed * Edinburgh</span>
        <h1 class="reveal reveal-delay-1">Soap that<br/><em>actually</em> cleans.</h1>
        <p class="reveal reveal-delay-2">Honest ingredients. No fillers. Just olive oil, coconut oil, and shea butter -- cured for four weeks so every bar lasts.</p>
        <div class="hero-cta reveal reveal-delay-3">
          <a href="/shop" class="btn">Shop the Collection</a>
          <a href="/blog/why-cold-pressed-is-better" class="btn btn-ghost">Our Process →</a>
        </div>
      </div>
      <div class="hero-soaps reveal reveal-delay-2" aria-hidden="true">
        <div class="soap-stack">
          <div class="soap soap-1"><span>Lavender</span></div>
          <div class="soap soap-2"><span>Citrus</span></div>
          <div class="soap soap-3"><span>Charcoal</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <div class="trust-bar">
    <div class="container trust-inner">
      <span class="trust-item">* 100% Natural Ingredients</span>
      <span class="trust-item">* Vegan &amp; Cruelty-Free</span>
      <span class="trust-item">* Cured 4 Weeks</span>
      <span class="trust-item">* Free UK Shipping over £30</span>
    </div>
  </div>

  <!-- FEATURED -->
  <section class="section-pad">
    <div class="container">
      <div class="ui-section-header reveal">
        <div>
          <span class="ui-eyebrow">Freshly Cut</span>
          <h2>Our bestsellers</h2>
        </div>
        <a href="/shop" class="btn btn-ghost">View all →</a>
      </div>
      <div class="ui-product-card-grid">
        {featuredProducts.map((product) => (
          <ProductCard
            title={product.title}
            price={product.price}
            imageColor={product.color}
            scent={product.scent}
            id={product.id}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- INGREDIENTS -->
  <section class="ingredients-section">
    <div class="container ingredients-inner">
      <div class="ing-visual reveal" aria-hidden="true">
        <div class="ing-circles">
          <div class="ing-circle olive"><span>Olive Oil</span></div>
          <div class="ing-circle coconut"><span>Coconut Oil</span></div>
          <div class="ing-circle shea"><span>Shea Butter</span></div>
        </div>
      </div>
      <div class="ing-text">
        <span class="ui-eyebrow reveal">Radical Transparency</span>
        <h2 class="reveal reveal-delay-1">Nothing to hide.</h2>
        <p class="reveal reveal-delay-2">Every bar starts with just three ingredients. The rest is craft -- the scent, the cut, the cure. No palm oil. No SLS. No synthetic fragrance.</p>
        <ul class="ing-list reveal reveal-delay-3">
          <li><strong>Organic Olive Oil</strong><span>Deep moisture that won't clog pores</span></li>
          <li><strong>Raw Coconut Oil</strong><span>Creates a rich, long-lasting lather</span></li>
          <li><strong>Unrefined Shea Butter</strong><span>Leaves skin silky and protected</span></li>
        </ul>
        <a href="/blog/why-cold-pressed-is-better" class="btn btn-outline reveal" style="margin-top:var(--sp-8)">Read Our Process →</a>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="section-pad">
    <div class="container">
      <div class="ui-section-header reveal" style="justify-content:center;text-align:center;margin-bottom:var(--sp-12)">
        <div>
          <span class="ui-eyebrow">Happy Customers</span>
          <h2>What people are saying</h2>
        </div>
      </div>
      <div class="testimonials-grid">
        <blockquote class="testimonial reveal">
          <p>"Switched from commercial soap six months ago and my skin has never felt better. The Lavender Dream is genuinely beautiful."</p>
          <cite>-- Sarah M., Edinburgh</cite>
        </blockquote>
        <blockquote class="testimonial reveal reveal-delay-1">
          <p>"I bought the Charcoal Detox for my husband. He went through it in two weeks and immediately asked for more."</p>
          <cite>-- Jamie T., Glasgow</cite>
        </blockquote>
        <blockquote class="testimonial reveal reveal-delay-2">
          <p>"Bought a gift set for my mum and she now orders for herself. The packaging is simple and the soaps last forever."</p>
          <cite>-- Priya K., London</cite>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- CTA BAND -->
  <section class="section-pad">
    <div class="container">
      <div class="cta-band reveal">
        <div>
          <h2>Ready to make the switch?</h2>
          <p>Every bar is hand-cut and shipped within 2 days.</p>
        </div>
        <a href="/shop" class="cta-btn">Shop Now →</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .hero { min-height: 100dvh; display:flex; align-items:center; position:relative; overflow:hidden; padding: calc(var(--header-h) + var(--sp-16)) 0 var(--sp-20); }
  .hero-bg { position:absolute; inset:0; z-index:0; pointer-events:none; }
  .blob { position:absolute; border-radius:50%; filter:blur(90px); opacity:0.3; }
  .blob-a { width:500px; height:500px; background:#D4C5A9; top:-100px; right:-80px; }
  .blob-b { width:350px; height:350px; background:#B8D4CC; bottom:0; left:-60px; }
  .hero-inner { position:relative; z-index:1; display:grid; grid-template-columns:1fr 1fr; gap:var(--sp-16); align-items:center; }
  .hero-text h1 { font-family:var(--font-display); font-size:var(--text-3xl); font-weight:300; line-height:1.08; margin-bottom:var(--sp-6); color:var(--clr-text); }
  .hero-text h1 em { font-style:italic; color:var(--clr-primary); }
  .hero-text p { font-size:var(--text-lg); color:var(--clr-text-muted); margin-bottom:var(--sp-8); max-width:44ch; }
  .hero-cta { display:flex; gap:var(--sp-4); flex-wrap:wrap; }
  .hero-soaps { display:flex; justify-content:center; }
  .soap-stack { position:relative; width:300px; height:320px; }
  .soap { position:absolute; border-radius:22px; display:flex; align-items:flex-end; justify-content:center; padding-bottom:var(--sp-4); box-shadow:var(--shadow-lg); }
  .soap span { font-size:var(--text-xs); font-weight:600; text-transform:uppercase; letter-spacing:0.1em; color:rgba(255,255,255,0.9); }
  .soap-1 { width:200px; height:130px; background:linear-gradient(135deg,#E0BBE4,#C9A0CE); top:0; left:50px; transform:rotate(-6deg); }
  .soap-2 { width:200px; height:130px; background:linear-gradient(135deg,#FFD6A5,#F5B87A); top:100px; left:20px; transform:rotate(3deg); }
  .soap-3 { width:200px; height:130px; background:linear-gradient(135deg,#5A5E7A,#3A3D55); top:185px; left:70px; transform:rotate(-2deg); }

  /* Trust bar */
  .trust-bar { border-top:1px solid var(--clr-border); border-bottom:1px solid var(--clr-border); padding:var(--sp-4) 0; background-color:var(--clr-surface); }
  .trust-inner { display:flex; align-items:center; justify-content:center; gap:var(--sp-8); flex-wrap:wrap; }
  .trust-item { font-size:var(--text-sm); color:var(--clr-text-muted); }

  /* Section shared */
  .section-pad { padding:var(--sp-24) 0; }
  /* Ingredients */
  .ingredients-section { padding:var(--sp-24) 0; background-color:var(--clr-surface); border-top:1px solid var(--clr-border); border-bottom:1px solid var(--clr-border); }
  .ingredients-inner { display:grid; grid-template-columns:1fr 1fr; gap:var(--sp-16); align-items:center; }
  .ing-circles { position:relative; width:100%; max-width:380px; aspect-ratio:1; margin:0 auto; }
  .ing-circle { position:absolute; border-radius:50%; display:flex; align-items:center; justify-content:center; transition:transform 0.5s ease; }
  .ing-circle:hover { transform:scale(1.08) !important; }
  .ing-circle span { font-size:var(--text-xs); font-weight:600; text-transform:uppercase; letter-spacing:0.08em; color:var(--clr-text); text-align:center; padding:var(--sp-2); }
  /* Pastel circles -- intentionally not theme-variable so they stay visible in both modes */
  .olive   { width:65%; height:65%; background:rgba(180,210,160,0.7); top:0; left:0; }
  .coconut { width:55%; height:55%; background:rgba(230,210,150,0.7); bottom:0; left:15%; }
  .shea    { width:50%; height:50%; background:rgba(240,200,150,0.7); top:20%; right:0; }
  .ing-text h2 { font-family:var(--font-display); font-size:var(--text-2xl); font-weight:400; color:var(--clr-text); margin-bottom:var(--sp-4); }
  .ing-text p { color:var(--clr-text-muted); font-size:var(--text-base); margin-bottom:var(--sp-8); max-width:42ch; }
  .ing-list { list-style:none; display:flex; flex-direction:column; gap:var(--sp-5); }
  .ing-list li { display:flex; flex-direction:column; gap:2px; padding-left:var(--sp-5); position:relative; }
  .ing-list li::before { content:''; position:absolute; left:0; top:8px; width:8px; height:8px; border-radius:50%; background:var(--clr-primary); }
  .ing-list strong { font-size:var(--text-base); font-weight:600; color:var(--clr-text); }
  .ing-list span { font-size:var(--text-sm); color:var(--clr-text-muted); }

  /* Testimonials */
  .testimonials-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:var(--sp-6); }
  .testimonial { background-color:var(--clr-surface); border:1px solid var(--clr-border); border-radius:var(--r-lg); padding:var(--sp-8); display:flex; flex-direction:column; gap:var(--sp-6); }
  .testimonial p { font-family:var(--font-display); font-size:var(--text-lg); font-style:italic; color:var(--clr-text); line-height:1.6; flex:1; }
  .testimonial cite { font-size:var(--text-sm); color:var(--clr-text-muted); font-style:normal; font-weight:600; }

  /* CTA band */
  .cta-band { background-color:var(--clr-primary); border-radius:var(--r-xl); padding:var(--sp-12) var(--sp-10); display:flex; align-items:center; justify-content:space-between; gap:var(--sp-8); flex-wrap:wrap; }
  .cta-band h2 { font-family:var(--font-display); font-size:var(--text-2xl); font-weight:400; color:#fff; margin-bottom:var(--sp-2); }
  .cta-band p { color:rgba(255,255,255,0.75); font-size:var(--text-base); }
  .cta-btn { display:inline-flex; align-items:center; padding:var(--sp-3) var(--sp-8); background:#fff; color:var(--clr-primary); border-radius:var(--r-full); font-size:var(--text-sm); font-weight:600; letter-spacing:0.04em; text-transform:uppercase; white-space:nowrap; transition:opacity var(--transition); }
  .cta-btn:hover { opacity:0.9; }

  /* Responsive */
  @media (max-width:900px) {
    .hero-inner { grid-template-columns:1fr; text-align:center; }
    .hero-cta { justify-content:center; }
    .hero-text p { margin-inline:auto; }
    .hero-soaps { display:none; }
    .ingredients-inner { grid-template-columns:1fr; }
  }
  @media (max-width:600px) {
    .cta-band { flex-direction:column; text-align:center; border-radius:var(--r-lg); }
  }
</style>
