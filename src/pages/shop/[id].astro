---
import Layout from '../../layouts/Layout.astro';
import { getAllProducts } from '../../lib/content';

export async function getStaticPaths() {
  const products = await getAllProducts();
  return products.map((product) => ({ params: { id: product.id }, props: { product } }));
}

const { product } = Astro.props;
---
<Layout title={product.title}>
  <section class="product-page" data-product-id={product.id}>
    <div class="container">
      <a href="/shop" class="ui-back-link back-link">← Back to Collection</a>
      <div class="product-grid">

        <!-- Visual -->
        <div class="visual-col">
          <div class="product-visual" style={`background-color:${product.color}22`}>
            <div class="soap-display" style={`background:linear-gradient(135deg,${product.color},${product.color}99)`}></div>
          </div>
        </div>

        <!-- Info -->
        <div class="info-col">
          <span class="scent-tag">{product.scent}</span>
          <h1>{product.title}</h1>
          <p class="price">£{product.price}</p>
          <div class="divider"></div>
          <p class="desc">{product.desc}</p>
          <div class="meta">
            <div class="meta-item">
              <strong>Key Ingredients</strong>
              <span>Olive Oil, Coconut Oil, Raw Shea Butter, Pure Essential Oils</span>
            </div>
            <div class="meta-item">
              <strong>Specifications</strong>
              <span>Hand-cut · Approx. 4.5 oz · Cured for 4 weeks</span>
            </div>
          </div>
          <button class="btn add-to-cart-btn"
            data-id={product.id} data-title={product.title}
            data-price={product.price} data-scent={product.scent}
            data-color={product.color.replace('#','')}>
            Add to Basket — £{product.price}
          </button>
        </div>

      </div>
    </div>
  </section>
</Layout>

<style>
  .product-page { padding: calc(var(--header-h) + var(--sp-12)) 0 var(--sp-24); }
  .back-link { margin-bottom:var(--sp-8); }
  .product-grid { display:grid; grid-template-columns:1fr 1fr; gap:var(--sp-16); align-items:center; }
  .product-visual {
    height:500px; border-radius:var(--r-xl);
    display:flex; align-items:center; justify-content:center;
    border:1px solid var(--clr-border);
  }
  .soap-display {
    width:260px; height:175px; border-radius:32px;
    box-shadow: inset -8px -8px 20px rgba(0,0,0,0.06), 15px 25px 45px rgba(0,0,0,0.12);
    transform:rotate(-8deg);
    transition:transform 0.5s cubic-bezier(0.34,1.56,0.64,1);
  }
  .product-visual:hover .soap-display { transform:rotate(0deg) scale(1.04); }
  .scent-tag { display:inline-block; font-size:var(--text-xs); font-weight:600; text-transform:uppercase; letter-spacing:0.15em; color:var(--clr-text-muted); margin-bottom:var(--sp-3); }
  h1 { font-family:var(--font-display); font-size:var(--text-3xl); font-weight:300; color:var(--clr-text); margin-bottom:var(--sp-3); line-height:1.1; }
  .price { font-family:var(--font-display); font-size:var(--text-2xl); font-weight:400; color:var(--clr-text); }
  .divider { width:100%; height:1px; background-color:var(--clr-border); margin:var(--sp-6) 0; }
  .desc { font-size:var(--text-lg); line-height:1.7; color:var(--clr-text-muted); margin-bottom:var(--sp-8); max-width:44ch; }
  .meta { display:flex; flex-direction:column; gap:var(--sp-5); margin-bottom:var(--sp-8); }
  .meta-item { display:flex; flex-direction:column; gap:4px; }
  .meta-item strong { font-size:var(--text-sm); font-weight:600; text-transform:uppercase; letter-spacing:0.08em; color:var(--clr-text); }
  .meta-item span { font-size:var(--text-sm); color:var(--clr-text-muted); }
  .add-to-cart-btn { width:100%; justify-content:center; font-size:var(--text-base); padding:var(--sp-4) var(--sp-8); }
  @media (max-width:900px) {
    .product-grid { grid-template-columns:1fr; gap:var(--sp-8); }
    .product-visual { height:300px; }
    .soap-display { width:180px; height:120px; }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const cartState = window.cartState;
    document.querySelector('.add-to-cart-btn')?.addEventListener('click', (e) => {
      const btn = e.currentTarget as HTMLElement;
      const { id, title, price, scent, color } = btn.dataset;
      if (!id || !title || !price || !scent || !color) {
        console.error('Missing product dataset for add-to-cart button');
        return;
      }

      cartState?.addItem({
        id,
        title,
        price,
        scent,
        color,
      });
      const orig = btn.textContent;
      btn.textContent = '✓ Added to Basket';
      setTimeout(() => { btn.textContent = orig; }, 2000);
    });
  });
</script>
